# Copy this file to .env for local development.
# In Render (or wherever server.js is deployed), set these as real environment
# variables in the dashboard instead — do not commit a .env file.

# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=

# Must be an address on a domain verified in your Resend account.
RESEND_FROM_EMAIL=noreply@nerdyphotographer.in

PORT=3000
